# ============================================================
# DATABASE (Neon PostgreSQL)
# ============================================================
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/line_chatbot?sslmode=require"

# ============================================================
# LINE Messaging API (Multi-channel)
# ใส่เป็น JSON array รองรับหลาย bot พร้อมกัน
# destination = Bot's User ID (ดูได้จาก webhook log ครั้งแรก)
# secret      = Channel Secret (32 ตัวอักษร)
# token       = Channel Access Token (string ยาว)
# ============================================================
CHANNELS='[{"name":"BotName","destination":"Uxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx","secret":"xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx","token":"xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"}]'

# ============================================================
# CLOUDINARY
# ดูได้จาก https://console.cloudinary.com > Dashboard
# ============================================================
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"

# ============================================================
# WEB LOGIN
# ============================================================
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="your_secure_password"
SESSION_SECRET="your_random_secret_string_at_least_32_chars"

# ============================================================
# SERVER
# ============================================================
PORT=3000
BASE_URL="https://your-domain.onrender.com"
